<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Switch to true to build against standard Microsoft WinForms -->
    <UseRealWinForms>false</UseRealWinForms>
    <!-- Switch to true to build for WebAssembly -->
    <UseWasm>false</UseWasm>

    <TargetFramework Condition="'$(UseRealWinForms)'=='true'">net9.0-windows</TargetFramework>
    <TargetFramework Condition="'$(UseRealWinForms)'!='true'">net9.0</TargetFramework>

    <RootNamespace>WinFormsX.Samples</RootNamespace>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RunAnalyzers>false</RunAnalyzers>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <PropertyGroup Condition="'$(UseRealWinForms)'=='true'">
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <!-- WASM-specific settings -->
  <PropertyGroup Condition="'$(UseWasm)'=='true'">
    <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
    <OutputType>Exe</OutputType>
    <WasmMainJSPath>wwwroot\main.js</WasmMainJSPath>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseRealWinForms)'!='true'">
    <ProjectReference Include="..\System.Windows.Forms\src\System.Windows.Forms.csproj" />
  </ItemGroup>

  <!-- Copy wwwroot content to WASM AppBundle -->
  <ItemGroup Condition="'$(UseWasm)'=='true'">
    <WasmExtraFilesToDeploy Include="wwwroot\index.html" />
    <WasmExtraFilesToDeploy Include="wwwroot\main.js" />
  </ItemGroup>

</Project>

